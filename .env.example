APP_NAME=Visual Search API
APP_ENV=development

API_HOST=127.0.0.1
API_PORT=8000

FRONTEND_API_URL=http://127.0.0.1:8000
FRONTEND_API_TIMEOUT_SECONDS=60

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=visual_search_multidataset_v1
QDRANT_TIMEOUT_SECONDS=120

DATASET_MODE=multidataset
DATASET_SOURCES=caltech256,food101,product_images,tiny_imagenet

HF_DATASET=ilee0022/Caltech-256
HF_CACHE_DIRECTORY=C:/hf-cache/datasets
HF_HOME=C:/hf-cache
HF_HUB_CACHE=C:/hf-cache/hub
HF_HUB_DISABLE_SYMLINKS_WARNING=1
HF_HUB_ENABLE_HF_TRANSFER=1

CALTECH256_DATASET=ilee0022/Caltech-256
FOOD101_DATASET=ethz/food101
PRODUCT_IMAGES_DATASET=ashraq/fashion-product-images-small
TINY_IMAGENET_DATASET=zh-plus/tiny-imagenet

CALTECH256_LIMIT=30607
FOOD101_LIMIT=20000
PRODUCT_IMAGES_LIMIT=25000
TINY_IMAGENET_LIMIT=20000

IMAGE_MODEL=clip-ViT-B-32
TEXT_MODEL=sentence-transformers/clip-ViT-B-32-multilingual-v1

DEVICE=cuda
BATCH_SIZE=32
UPSERT_BATCH_SIZE=128
NUM_WORKERS=0
PREFETCH_FACTOR=2

DEFAULT_TOP_K=12
MAX_TOP_K=50
MAX_UPLOAD_MB=10

IMAGE_DIRECTORY=data/images
THUMBNAIL_DIRECTORY=data/thumbnails
MANIFEST_DIRECTORY=data/manifests
EMBEDDING_DIRECTORY=data/embeddings

EMBEDDING_FILENAME=visual_search_multidataset_clip_vit_b32.npy